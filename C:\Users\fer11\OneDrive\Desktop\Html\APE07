import java.util.Random;
import java.util.Arrays;
import java.util.Scanner;

public class Paquete {
    int id;
    int[] arreglo;

    Paquete(int id) {
        this.id = id;
    }

    void Buscarlineal() {
        Scanner consola = new Scanner(System.in);
        Random random = new Random();
        arreglo = new int[10000];
        for (int x = 0; x < arreglo.length; x++) {
            arreglo[x] = random.nextInt(100000);
        }
        System.out.println("Elige el valor que quieres encontrar");
        int valor_Encontrar = consola.nextInt();

        long inicio = System.nanoTime();

        boolean encontrado = false;
        for (int y = 0; y < arreglo.length; y++) {
            if (valor_Encontrar == arreglo[y]) {
                System.out.println("Su valor es = " + arreglo[y]);
                encontrado = true;
            }
        }
        if (!encontrado) {
            System.out.println("No se encontro su paquete");
        }

        long tiempo = System.nanoTime() - inicio;
        System.out.println("Tiempo de busqueda lineal: " + tiempo / 1e6 + " ms");
    }

    public static void main(String[] args) {
        var paquete = new Paquete(1);
        paquete.Buscarlineal();
    }
}
